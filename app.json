{
  "expo": {
    "name": "HisaabKitab",
    "slug": "hisaabkitab",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7B4B2A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hisaabkitab.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#7B4B2A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.hisaabkitab.app"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-secure-store",
      "expo-localization",
      "expo-barcode-scanner",
      "expo-asset",
      "expo-font",
      ["@jamsch/expo-speech-recognition", {
        "speechRecognitionPermission": "Allow HisaabKitab to use speech recognition for voice commands.",
        "microphonePermission": "Allow HisaabKitab to use the microphone for voice commands."
      }]
    ]
  }
}
